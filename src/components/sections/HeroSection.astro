<style>
  .hero-shell {
    isolation: isolate;
  }

  /* Title gradient — white through orange into cyan */
  .hero-title-main {
    background: linear-gradient(135deg, #ffffff 0%, #fb923c 38%, #f97316 52%, #7dd3fc 78%, #c8deff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ── Primary CTA ── */
  .hero-cta-primary {
    box-shadow:
      0 0 20px rgba(125, 211, 252, 0.25),
      0 0 60px rgba(125, 211, 252, 0.08);
  }
  .hero-cta-primary:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow:
      0 0 28px rgba(125, 211, 252, 0.4),
      0 0 80px rgba(125, 211, 252, 0.15),
      0 4px 20px rgba(0, 0, 0, 0.3);
  }
  .hero-cta-primary:active {
    transform: translateY(1px) scale(0.97);
    box-shadow:
      0 0 12px rgba(125, 211, 252, 0.3),
      0 0 40px rgba(125, 211, 252, 0.1);
    transition-duration: 100ms;
  }

  /* Shine sweep on hover */
  .hero-cta-shine {
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.35) 50%,
      transparent 70%
    );
    transform: translateX(-120%);
    transition: none;
  }
  .hero-cta-primary:hover .hero-cta-shine {
    transform: translateX(120%);
    transition: transform 0.6s ease;
  }

  /* Glass badge glow */
  .glass-badge {
    box-shadow:
      0 0 20px rgba(125, 211, 252, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  /* Radar sweep rotation */
  .hud-radar-sweep {
    transform-origin: 0 0;
    animation: radarSpin 4s linear infinite;
  }

  @keyframes radarSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ── EQ Visualizer bars ── */
  .eq-bar {
    animation: eqBounce 1.2s ease-in-out infinite alternate;
  }
  .eq-bar-1 { animation-delay: 0s; animation-duration: 0.9s; }
  .eq-bar-2 { animation-delay: 0.15s; animation-duration: 1.1s; }
  .eq-bar-3 { animation-delay: 0.05s; animation-duration: 0.8s; }
  .eq-bar-4 { animation-delay: 0.2s; animation-duration: 1.3s; }
  .eq-bar-5 { animation-delay: 0.1s; animation-duration: 1.0s; }
  .eq-bar-6 { animation-delay: 0.25s; animation-duration: 0.85s; }
  .eq-bar-7 { animation-delay: 0.08s; animation-duration: 1.15s; }
  .eq-bar-8 { animation-delay: 0.18s; animation-duration: 0.95s; }

  @keyframes eqBounce {
    0%   { transform: scaleY(1); }
    100% { transform: scaleY(0.3); }
  }

  /* ── Targeting reticle pulse ── */
  .reticle-outer {
    transform-origin: center;
    animation: reticlePulseOuter 3s ease-in-out infinite;
  }
  .reticle-inner {
    transform-origin: center;
    animation: reticlePulseInner 2.4s ease-in-out infinite;
  }
  .reticle-diamond {
    transform-origin: center;
    animation: diamondPulse 2s ease-in-out infinite;
  }
  .reticle-dot {
    animation: dotGlow 1.6s ease-in-out infinite;
  }
  .reticle-halo {
    transform-origin: center;
    animation: haloExpand 2s ease-in-out infinite;
  }
  .reticle-ticks {
    animation: tickFlash 3s ease-in-out infinite;
  }

  @keyframes reticlePulseOuter {
    0%, 100% { stroke-opacity: 0.2; transform: scale(1); }
    50%      { stroke-opacity: 0.45; transform: scale(1.04); }
  }
  @keyframes reticlePulseInner {
    0%, 100% { stroke-opacity: 0.3; transform: scale(1); }
    50%      { stroke-opacity: 0.6; transform: scale(1.06); }
  }
  @keyframes diamondPulse {
    0%, 100% { transform: scale(1); fill-opacity: 0.15; stroke-opacity: 0.6; }
    50%      { transform: scale(1.1); fill-opacity: 0.3; stroke-opacity: 1; }
  }
  @keyframes dotGlow {
    0%, 100% { opacity: 0.9; r: 3; }
    50%      { opacity: 1; r: 4.5; }
  }
  @keyframes haloExpand {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50%      { transform: scale(1.5); opacity: 0.15; }
  }
  @keyframes tickFlash {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 0.7; }
  }
</style>
