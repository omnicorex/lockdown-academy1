---
import { brandingConfig } from "../config/branding";
import Logo from "./Logo.astro";
---

<nav id="main-nav" class="fixed top-0 z-50 w-full border-b border-white/[0.06] bg-page/80 backdrop-blur-xl">
  <div class="shell flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5" style="font-family: var(--font-display);">
      <Logo size={30} />
      <span class="text-xl tracking-[0.06em] text-white">LOCKDOWN</span>
      <span class="text-xl tracking-[0.06em] text-white/40">ACADEMY</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a href="#authority" class="text-[0.75rem] font-500 uppercase tracking-[0.18em] text-white/40 transition-colors duration-200 hover:text-white/80" style="font-family: var(--font-body);">About</a>
      <a href="#how-it-works" class="text-[0.75rem] font-500 uppercase tracking-[0.18em] text-white/40 transition-colors duration-200 hover:text-white/80" style="font-family: var(--font-body);">How It Works</a>
      <a href="#what-you-get" class="text-[0.75rem] font-500 uppercase tracking-[0.18em] text-white/40 transition-colors duration-200 hover:text-white/80" style="font-family: var(--font-body);">Program</a>
      <a href="#pricing" class="text-[0.75rem] font-500 uppercase tracking-[0.18em] text-white/40 transition-colors duration-200 hover:text-white/80" style="font-family: var(--font-body);">Pricing</a>
    </div>

    <a
      href="#pricing"
      class="hidden rounded-full border border-highlight/30 bg-highlight/10 px-5 py-2 text-[0.68rem] font-700 uppercase tracking-[0.18em] text-highlight-warm transition-all duration-200 hover:bg-highlight/20 hover:text-white md:inline-flex"
      style="font-family: var(--font-body);"
    >
      Get Started
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="relative flex h-10 w-10 items-center justify-center rounded-lg text-white/50 transition-colors hover:text-white md:hidden"
      aria-label="Menu"
      aria-expanded="false"
    >
      <span class="hamburger-icon">
        <span class="hamburger-line hamburger-line-1"></span>
        <span class="hamburger-line hamburger-line-2"></span>
        <span class="hamburger-line hamburger-line-3"></span>
      </span>
    </button>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="mobile-menu pointer-events-none md:hidden"
    aria-hidden="true"
  >
    <div class="mobile-menu-inner mx-4 mb-4 overflow-hidden rounded-2xl border border-white/[0.08] bg-page/70 shadow-[0_8px_40px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur-2xl">
      <div class="flex flex-col px-2 py-3">
        <a href="#authority" class="mobile-nav-link" style="font-family: var(--font-body);" data-index="0">
          <span class="mobile-nav-dot"></span>
          About
        </a>
        <a href="#how-it-works" class="mobile-nav-link" style="font-family: var(--font-body);" data-index="1">
          <span class="mobile-nav-dot"></span>
          How It Works
        </a>
        <a href="#what-you-get" class="mobile-nav-link" style="font-family: var(--font-body);" data-index="2">
          <span class="mobile-nav-dot"></span>
          Program
        </a>
        <a href="#pricing" class="mobile-nav-link" style="font-family: var(--font-body);" data-index="3">
          <span class="mobile-nav-dot"></span>
          Pricing
        </a>
      </div>
      <div class="border-t border-white/[0.06] px-4 py-4">
        <a
          href="#pricing"
          class="flex w-full items-center justify-center rounded-full border border-highlight/30 bg-highlight/10 py-3 text-[0.68rem] font-700 uppercase tracking-[0.18em] text-highlight-warm transition-all duration-200 hover:bg-highlight/20 hover:text-white"
          style="font-family: var(--font-body);"
        >
          Get Started
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  /* ── Hamburger icon ── */
  .hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 18px;
  }
  .hamburger-line {
    display: block;
    height: 2px;
    width: 100%;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.35s cubic-bezier(0.77, 0, 0.175, 1),
                opacity 0.25s ease,
                width 0.3s cubic-bezier(0.77, 0, 0.175, 1);
    transform-origin: center;
  }
  .hamburger-line-2 {
    width: 12px;
  }

  /* Open state → X morphs */
  .menu-open .hamburger-line-1 {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-open .hamburger-line-2 {
    opacity: 0;
    width: 0;
  }
  .menu-open .hamburger-line-3 {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile dropdown ── */
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transform: translateY(-8px);
    transition: max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.3s ease,
                transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-menu.is-open {
    pointer-events: auto;
    max-height: 400px;
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Nav links ── */
  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.2s ease, background 0.2s ease;
    /* stagger entrance */
    opacity: 0;
    transform: translateX(-12px);
    transition: color 0.2s ease,
                background 0.2s ease,
                opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-nav-link:hover,
  .mobile-nav-link:active {
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.04);
  }

  /* stagger visible state */
  .mobile-menu.is-open .mobile-nav-link {
    opacity: 1;
    transform: translateX(0);
  }
  .mobile-menu.is-open .mobile-nav-link[data-index="0"] { transition-delay: 0.06s; }
  .mobile-menu.is-open .mobile-nav-link[data-index="1"] { transition-delay: 0.1s; }
  .mobile-menu.is-open .mobile-nav-link[data-index="2"] { transition-delay: 0.14s; }
  .mobile-menu.is-open .mobile-nav-link[data-index="3"] { transition-delay: 0.18s; }

  /* Reset delay on close so they don't linger */
  .mobile-nav-link[data-index="0"] { transition-delay: 0s; }
  .mobile-nav-link[data-index="1"] { transition-delay: 0s; }
  .mobile-nav-link[data-index="2"] { transition-delay: 0s; }
  .mobile-nav-link[data-index="3"] { transition-delay: 0s; }

  /* ── Nav dot accent ── */
  .mobile-nav-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-highlight);
    opacity: 0.5;
    flex-shrink: 0;
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
  }
  .mobile-nav-link:hover .mobile-nav-dot {
    opacity: 1;
    box-shadow: 0 0 8px rgba(249, 115, 22, 0.5);
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = menu?.querySelectorAll('a');

  function toggle() {
    const isOpen = menu?.classList.contains('is-open');
    if (isOpen) {
      close();
    } else {
      open();
    }
  }

  function open() {
    menu?.classList.add('is-open');
    btn?.classList.add('menu-open');
    btn?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
  }

  function close() {
    menu?.classList.remove('is-open');
    btn?.classList.remove('menu-open');
    btn?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
  }

  btn?.addEventListener('click', toggle);

  // Close on link click
  links?.forEach(link => {
    link.addEventListener('click', () => {
      close();
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    const nav = document.getElementById('main-nav');
    if (nav && !nav.contains(e.target as Node)) {
      close();
    }
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
