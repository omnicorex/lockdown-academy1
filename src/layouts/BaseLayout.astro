---
import "../styles/global.css";
import { brandingConfig } from "../config/branding";
import { siteConfig } from "../config/site";
import { typographyConfig } from "../config/typography";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  path?: string;
}

const {
  title = brandingConfig.siteName,
  description = siteConfig.description,
  image = siteConfig.ogImage,
  path = siteConfig.path
} = Astro.props;

const pageTitle =
  title === brandingConfig.siteName ? title : `${title} | ${brandingConfig.siteName}`;
const canonical = new URL(path, Astro.site ?? siteConfig.url).toString();
const socialImage = new URL(image, Astro.site ?? siteConfig.url).toString();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050816" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    <!-- Favicons: replace these files in /public/ with your own -->
    <!-- Generate a full set at https://realfavicongenerator.net -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brandingConfig.siteName} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:site" content={brandingConfig.socialHandle} />

    <slot name="head" />
  </head>
  <body
    class="bg-page text-copy antialiased"
    style={`font-family:${typographyConfig.body}; --font-display:${typographyConfig.display}; --font-body:${typographyConfig.body}; --font-mono:${typographyConfig.mono};`}
  >
    <slot />
  </body>
</html>
